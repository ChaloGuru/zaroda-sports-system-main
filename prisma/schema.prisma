generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ─────────────────────────────────────────────────────────────────────────
// Enums
// ─────────────────────────────────────────────────────────────────────────

enum Role {
  SUPER_ADMIN
  TENANT_OWNER
  TOURNAMENT_ADMIN
  SCOREKEEPER
  OFFICIAL
  GAME_COORDINATOR
  CHIEF_CALLROOM_MANAGER
  CHIEF_TRACK_JUDGE
  CHIEF_FIELD_JUDGE
  CHIEF_RECORDER
  TEAM_MANAGER
}

enum AccountType {
  SCHOOL
  OPEN_TOURNAMENT
}

enum GameCategory {
  BALL_GAMES
  ATHLETICS
  MUSIC
  OTHER_GAMES
}

// Matches lib/scoring.ts's BallSport union exactly - drives which
// win/draw/loss points config computeStandings applies to a game's fixtures.
// Despite the name (kept to avoid a wider rename across schema/scoring/UI),
// this also covers the dual/team-match "indoor games" run at higher
// competition levels (chess, table tennis, badminton) - they use the same
// fixtures/standings pipeline as the ball sports above.
enum BallSport {
  FOOTBALL
  BASKETBALL
  VOLLEYBALL
  HANDBALL
  RUGBY
  NETBALL
  CHESS
  TABLE_TENNIS
  BADMINTON
}

enum Level {
  BASE
  ZONE
  SUB_COUNTY
  COUNTY
  REGIONAL
  NATIONAL
  // A standalone open tournament (accountType OPEN_TOURNAMENT) - not part of
  // the school competition ladder above, so it's excluded from LEVEL_ORDER/
  // isHigherLevel and geographic restriction (lib/utils.ts, lib/authorize.ts).
  OPEN_TOURNAMENT
}

// Championship.schoolLevel only ever uses PRIMARY_JS / SENIOR_SCHOOL / TERTIARY
// (the three subscription/pricing tiers). Game.schoolLevel additionally allows
// the granular PRIMARY / JS values, used only within a PRIMARY_JS championship
// to record which of the two a specific event is for; enforced at the
// application layer via separate Zod schemas per model (lib/validations.ts).
enum SchoolLevel {
  PRIMARY
  JS
  PRIMARY_JS
  SENIOR_SCHOOL
  TERTIARY
}

enum Gender {
  BOYS
  GIRLS
  MIXED
}

enum ParticipantStatus {
  REGISTERED
  CONFIRMED_IN_CALL_ROOM
  DISQUALIFIED
}

enum PackageTier {
  ESSENTIAL
  // Reserved for future tiers - adding a new value here never requires
  // a schema rewrite, only a migration to extend the enum.
  PROFESSIONAL
  ELITE
  SEASON_BUNDLE
}

enum SubscriptionStatus {
  TRIAL
  ACTIVE
  EXPIRED
}

enum PaymentStatus {
  PENDING
  PAID
  FAILED
}

enum TeamPaymentStatus {
  PENDING
  PAID
  FAILED
}

// Tracks a tenant's Paystack Subaccount used to receive open-tournament team
// registration fees directly (see lib/paystack.ts createPaystackSubaccount) -
// entirely separate from the Zaroda subscription flow (PaymentTransaction).
enum SubaccountStatus {
  NOT_CONFIGURED
  PENDING
  ACTIVE
  FAILED
}

enum AuditOp {
  INSERT
  UPDATE
  DELETE
}

// ─────────────────────────────────────────────────────────────────────────
// Core tenancy & auth
// ─────────────────────────────────────────────────────────────────────────

model User {
  id           String   @id @default(uuid())
  email        String   @unique
  passwordHash String
  name         String
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  roles                UserRole[]
  tenant               Tenant?
  createdChampionships Championship[] @relation("ChampionshipCreatedBy")
  sentMessages         AdminMessage[] @relation("MessageSender")
  receivedMessages     AdminMessage[] @relation("MessageRecipient")
  notifications        Notification[]
  auditLogs            AuditLog[]
  postedCirculars      ChampionshipCircular[]

  @@map("users")
}

model UserRole {
  id             String   @id @default(uuid())
  userId         String
  role           Role
  championshipId String?
  // Only set (and only meaningful) for TEAM_MANAGER - scopes the role to a
  // single organization's team rows within the championship (matched by
  // trimmed/lowercased TournamentTeam.name, the same org-identity convention
  // used elsewhere - see lib/organization-rankings.ts).
  organizationName String?
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  user         User          @relation(fields: [userId], references: [id], onDelete: Cascade)
  championship Championship? @relation(fields: [championshipId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([championshipId])
  @@map("user_roles")
}

model Tenant {
  id               String       @id @default(uuid())
  organizationName String
  contactName      String
  email            String       @unique
  phone            String
  accountType      AccountType
  county           String
  subcounty        String
  gameCategory     GameCategory
  userId           String       @unique
  lastActiveAt     DateTime     @default(now())
  createdAt        DateTime     @default(now())
  updatedAt        DateTime     @updatedAt

  // Paystack Subaccount for open-tournament team registration fees - 100% of
  // every team_fee payment settles here (percentage_charge: 0, see
  // lib/paystack.ts createPaystackSubaccount), never to Zaroda's main
  // account. Entirely separate from subscriptions/PaymentTransaction above.
  paystackSubaccountCode  String?           @unique
  settlementBankCode      String?
  settlementBankName      String?
  settlementAccountNumber String?
  settlementAccountName   String?
  subaccountStatus        SubaccountStatus  @default(NOT_CONFIGURED)

  user                User                       @relation(fields: [userId], references: [id], onDelete: Cascade)
  championships       Championship[]
  subscriptions       ChampionshipSubscription[]
  paymentTransactions PaymentTransaction[]

  @@map("tenants")
}

// ─────────────────────────────────────────────────────────────────────────
// Competition structure
// ─────────────────────────────────────────────────────────────────────────

model Championship {
  id          String       @id @default(uuid())
  tenantId    String
  name        String
  level       Level
  schoolLevel SchoolLevel
  category    GameCategory
  county      String
  location    String
  startDate   DateTime
  endDate     DateTime
  isPublished Boolean      @default(false)
  createdBy   String
  createdAt   DateTime     @default(now())
  updatedAt   DateTime     @updatedAt

  tenant          Tenant                     @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  creator         User                       @relation("ChampionshipCreatedBy", fields: [createdBy], references: [id])
  userRoles       UserRole[]
  games           Game[]
  participants    Participant[]
  tournamentTeams TournamentTeam[]
  bibRanges       SchoolBibRange[]
  subscriptions   ChampionshipSubscription[]
  fees            ChampionshipFee[]
  teamFeePayments TeamFeePayment[]
  circulars       ChampionshipCircular[]

  @@index([tenantId])
  @@map("championships")
}

model School {
  id        String   @id @default(uuid())
  name      String
  zone      String
  subcounty String
  county    String
  region    String
  country   String   @default("Kenya")
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  participants Participant[]
  bibRanges    SchoolBibRange[]

  @@map("schools")
}

// A group-stage pool within a game (e.g. "Pool A"). Teams assigned to a pool
// play a round robin within it; results feed pool standings; qualifying
// teams then advance to knockout-stage fixtures (recorded as ordinary
// MatchPool rows with a roundName like "Semi Final" - no separate model
// needed for the knockout stage itself).
model Pool {
  id        String   @id @default(uuid())
  gameId    String
  name      String
  createdAt DateTime @default(now())

  game       Game             @relation(fields: [gameId], references: [id], onDelete: Cascade)
  teams      TournamentTeam[]
  matchPools MatchPool[]

  @@index([gameId])
  @@map("pools")
}

model TournamentTeam {
  id             String   @id @default(uuid())
  championshipId String
  // The game a team is registered for - gender is derived from this game
  // rather than asked separately. Nullable because the public team_fee
  // self-registration flow (no specific game chosen) doesn't set it.
  gameId         String?
  // Optional group-stage pool within that game (e.g. "Pool A").
  poolId         String?
  name           String
  teamCode       String?
  gender         Gender   @default(MIXED)
  teamColor      String?
  contactName    String?
  contactEmail   String?
  contactPhone   String?
  notes          String?
  // Self-reported county of the registering institution/organization - used
  // to enforce the championship's geographic scope (see requireGeographicScope
  // in lib/authorize.ts) for BASE/ZONE/SUB_COUNTY/COUNTY-level championships.
  county         String?
  // Set when this team row was auto-created by promoting a winning team from
  // a lower-level championship (see /api/tournament-teams/promote) - points
  // at the origin TournamentTeam row in the other championship, for
  // traceability beyond just matching on name.
  promotedFromTeamId String?
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  championship  Championship     @relation(fields: [championshipId], references: [id], onDelete: Cascade)
  game          Game?            @relation(fields: [gameId], references: [id], onDelete: SetNull)
  pool          Pool?            @relation(fields: [poolId], references: [id], onDelete: SetNull)
  participants  Participant[]
  feePayments   TeamFeePayment[]
  promotedFrom  TournamentTeam?  @relation("TeamPromotion", fields: [promotedFromTeamId], references: [id], onDelete: SetNull)
  promotedTo    TournamentTeam[] @relation("TeamPromotion")

  @@unique([championshipId, teamCode])
  @@index([poolId])
  @@map("tournament_teams")
}

model Game {
  id             String       @id @default(uuid())
  championshipId String
  name           String
  category       GameCategory
  gender         Gender
  schoolLevel    SchoolLevel
  isTimed        Boolean
  sport          BallSport?
  maxQualifiers  Int          @default(5)
  raceType       String?
  scheduledDate  DateTime?
  createdAt      DateTime     @default(now())
  updatedAt      DateTime     @updatedAt

  championship    Championship     @relation(fields: [championshipId], references: [id], onDelete: Cascade)
  participants    Participant[]
  heats           Heat[]
  matchPools      MatchPool[]
  tournamentTeams TournamentTeam[]
  pools           Pool[]

  @@index([championshipId])
  @@map("games")
}

model Participant {
  id               String            @id @default(uuid())
  championshipId   String
  gameId           String
  schoolId         String?
  tournamentTeamId String?
  firstName        String
  lastName         String
  gender           Gender
  dateOfBirth      DateTime?
  bibNumber        Int
  laneNumber       Int?
  personalBest     Decimal?          @db.Decimal(10, 3)
  timeTaken        Decimal?          @db.Decimal(10, 3)
  position         Int?
  score            Decimal?          @db.Decimal(10, 3)
  isQualified      Boolean           @default(false)
  status           ParticipantStatus @default(REGISTERED)
  notes            String?
  // Ball-game team roster fields - a squad player's shirt number (unique
  // only within the team, unlike bibNumber which is unique championship-wide)
  // and playing position (e.g. "Striker", "Goalkeeper"). Both optional.
  jerseyNumber     Int?
  playingPosition  String?
  // Set when this participant row was auto-created by promoting a qualifying
  // finalist from a lower-level championship (see /api/participants/promote)
  // - points at the origin Participant row in the other championship, so
  // re-running promotion skips athletes already carried forward.
  promotedFromParticipantId String?
  createdAt        DateTime          @default(now())
  updatedAt        DateTime          @updatedAt

  championship       Championship      @relation(fields: [championshipId], references: [id], onDelete: Cascade)
  game               Game              @relation(fields: [gameId], references: [id], onDelete: Cascade)
  school             School?           @relation(fields: [schoolId], references: [id])
  tournamentTeam     TournamentTeam?   @relation(fields: [tournamentTeamId], references: [id])
  heatParticipations HeatParticipant[]

  @@unique([championshipId, bibNumber])
  @@index([gameId])
  @@index([schoolId])
  @@index([tournamentTeamId])
  @@map("participants")
}

model Heat {
  id         String   @id @default(uuid())
  gameId     String
  heatNumber Int
  heatType   String   @default("heat")
  createdAt  DateTime @default(now())

  game         Game              @relation(fields: [gameId], references: [id], onDelete: Cascade)
  participants HeatParticipant[]

  @@index([gameId])
  @@map("heats")
}

model HeatParticipant {
  id                  String   @id @default(uuid())
  heatId              String
  participantId       String
  timeTaken           Decimal? @db.Decimal(10, 3)
  position            Int?
  laneNumber          Int?
  score               Decimal? @db.Decimal(10, 3)
  isQualifiedForFinal Boolean  @default(false)
  createdAt           DateTime @default(now())

  heat        Heat        @relation(fields: [heatId], references: [id], onDelete: Cascade)
  participant Participant @relation(fields: [participantId], references: [id], onDelete: Cascade)

  @@unique([heatId, participantId])
  @@index([participantId])
  @@map("heat_participants")
}

// teamAId / teamBId can reference either a TournamentTeam or a School depending
// on competition type; stored as plain UUID columns (no FK enforced across two
// possible parent tables) and resolved in application code by championship type.
model MatchPool {
  id         String    @id @default(uuid())
  gameId     String
  // Set when this fixture was auto-generated as part of a pool's round
  // robin; null for manually-added fixtures (i.e. the knockout stage).
  // Lets the UI robustly separate "Pool Stage" from "Knockout Stage"
  // fixtures without guessing from the free-text roundName.
  poolId     String?
  roundName  String    @default("Round 1")
  // Which calendar day this fixture is played on - only meaningful once a
  // championship spans more than one day (Championship.startDate !=
  // endDate); left null for single-day championships and for fixtures not
  // yet scheduled to a specific day.
  matchDate  DateTime?
  teamAId    String
  teamBId    String
  teamAScore Int?
  teamBScore Int?
  winnerId   String?
  // True when this fixture was decided by one team failing to turn up rather
  // than being played out. winnerId still names the awarded (present) team;
  // teamAScore/teamBScore stay null since no match was actually played, and
  // computeStandings excludes the absent team from that game's standings
  // entirely unless it has at least one other real (non-walkover) match.
  isWalkover Boolean   @default(false)
  notes      String?
  createdAt  DateTime  @default(now())
  updatedAt  DateTime  @updatedAt

  game Game  @relation(fields: [gameId], references: [id], onDelete: Cascade)
  pool Pool? @relation(fields: [poolId], references: [id], onDelete: SetNull)

  @@index([gameId])
  @@index([poolId])
  @@map("match_pools")
}

model SchoolBibRange {
  id             String   @id @default(uuid())
  championshipId String
  schoolId       String
  rangeStart     Int
  rangeEnd       Int
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  championship Championship @relation(fields: [championshipId], references: [id], onDelete: Cascade)
  school       School       @relation(fields: [schoolId], references: [id], onDelete: Cascade)

  @@unique([championshipId, schoolId])
  @@map("school_bib_ranges")
}

// ─────────────────────────────────────────────────────────────────────────
// Monetization
// ─────────────────────────────────────────────────────────────────────────

model SubscriptionPlan {
  id          String      @id @default(uuid())
  displayName String
  packageTier PackageTier @default(ESSENTIAL)
  level       Level
  priceKes    Int
  isActive    Boolean     @default(true)
  createdAt   DateTime    @default(now())
  updatedAt   DateTime    @updatedAt

  subscriptions ChampionshipSubscription[]
  transactions  PaymentTransaction[]

  @@unique([packageTier, level])
  @@map("subscription_plans")
}

model ChampionshipSubscription {
  id             String             @id @default(uuid())
  tenantId       String
  planId         String
  championshipId String?
  category       GameCategory?
  status         SubscriptionStatus @default(TRIAL)
  trialStartedAt DateTime           @default(now())
  trialEndsAt    DateTime
  paidAt         DateTime?
  expiresAt      DateTime?
  amountPaidKes  Int?
  paystackReference String?
  createdAt      DateTime           @default(now())
  updatedAt      DateTime           @updatedAt

  tenant       Tenant           @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  plan         SubscriptionPlan @relation(fields: [planId], references: [id])
  championship Championship?    @relation(fields: [championshipId], references: [id])

  @@index([tenantId])
  @@index([championshipId])
  @@map("championship_subscriptions")
}

model PaymentTransaction {
  id                String        @id @default(uuid())
  tenantId          String
  planId            String
  paystackReference String        @unique
  amountKes         Int
  status            PaymentStatus @default(PENDING)
  paystackResponse  Json?
  createdAt         DateTime      @default(now())
  updatedAt         DateTime      @updatedAt

  tenant Tenant           @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  plan   SubscriptionPlan @relation(fields: [planId], references: [id])

  @@index([tenantId])
  @@map("payment_transactions")
}

model ChampionshipFee {
  id             String   @id @default(uuid())
  championshipId String
  name           String
  description    String?
  amountKes      Int
  isRequired     Boolean  @default(true)
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  championship Championship     @relation(fields: [championshipId], references: [id], onDelete: Cascade)
  payments     TeamFeePayment[]

  @@index([championshipId])
  @@map("championship_fees")
}

model ChampionshipCircular {
  id             String   @id @default(uuid())
  championshipId String
  title          String
  body           String
  postedById     String
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  championship Championship @relation(fields: [championshipId], references: [id], onDelete: Cascade)
  postedBy     User         @relation(fields: [postedById], references: [id])

  @@index([championshipId])
  @@map("championship_circulars")
}

model TeamFeePayment {
  id                String            @id @default(uuid())
  teamId            String
  feeId             String
  championshipId    String
  amountKes         Int
  status            TeamPaymentStatus @default(PENDING)
  paystackReference String?
  paidAt            DateTime?
  notes             String?
  createdAt         DateTime          @default(now())
  updatedAt         DateTime          @updatedAt

  team         TournamentTeam  @relation(fields: [teamId], references: [id], onDelete: Cascade)
  fee          ChampionshipFee @relation(fields: [feeId], references: [id], onDelete: Cascade)
  championship Championship    @relation(fields: [championshipId], references: [id], onDelete: Cascade)

  @@index([teamId])
  @@index([championshipId])
  @@map("team_fee_payments")
}

// ─────────────────────────────────────────────────────────────────────────
// Communication & audit
// ─────────────────────────────────────────────────────────────────────────

model Circular {
  id          String   @id @default(uuid())
  title       String
  content     String
  senderName  String
  senderRole  String   @default("National Admin")
  targetLevel Level    @default(NATIONAL)
  isPublished Boolean  @default(true)
  documentUrl String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@map("circulars")
}

model AdminMessage {
  id          String    @id @default(uuid())
  senderId    String
  recipientId String?
  parentId    String?
  subject     String
  body        String
  isBroadcast Boolean   @default(false)
  readAt      DateTime?
  createdAt   DateTime  @default(now())

  sender    User           @relation("MessageSender", fields: [senderId], references: [id], onDelete: Cascade)
  recipient User?          @relation("MessageRecipient", fields: [recipientId], references: [id], onDelete: Cascade)
  parent    AdminMessage?  @relation("MessageThread", fields: [parentId], references: [id], onDelete: NoAction, onUpdate: NoAction)
  replies   AdminMessage[] @relation("MessageThread")

  @@index([senderId])
  @@index([recipientId])
  @@index([parentId])
  @@map("admin_messages")
}

model Notification {
  id        String   @id @default(uuid())
  userId    String
  title     String
  body      String
  type      String
  link      String?
  isRead    Boolean  @default(false)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@map("notifications")
}

model AuditLog {
  id        String   @id @default(uuid())
  changedBy String?
  changedAt DateTime @default(now())
  operation AuditOp
  tableName String
  recordId  String
  oldData   Json?
  newData   Json?

  changer User? @relation(fields: [changedBy], references: [id], onDelete: SetNull)

  @@index([tableName, recordId])
  @@index([changedBy])
  @@map("audit_logs")
}
